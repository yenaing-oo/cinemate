{
    "name": "cinemate",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "check": "pnpm lint && tsc --noEmit && pnpm format:check",
        "db:generate": "prisma migrate dev",
        "db:migrate": "prisma migrate deploy",
        "db:push": "prisma db push",
        "db:reset": "prisma migrate reset",
        "db:seed": "pnpm tsx prisma/seed.ts",
        "db:seed:booking-loadtest": "dotenv -e .env -e load-tests/.env -- pnpm tsx prisma/seed-booking-loadtest.ts",
        "db:seed:watch-party-loadtest": "dotenv -e .env -e load-tests/.env -- pnpm tsx prisma/seed-watch-party-loadtest.ts",
        "db:studio": "prisma studio",
        "db:test:prepare": "dotenv -e .env.test -- prisma db push --force-reset --skip-generate",
        "dev": "next dev --turbo",
        "dev:loadtest": "dotenv -e .env -v LOAD_TEST_MODE=true -- next dev --turbo",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
        "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
        "postinstall": "prisma generate",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "preview": "next build && next start",
        "start": "next start",
        "test": "vitest",
        "test:load": "docker compose run --rm k6",
        "test:load:dashboard": "docker compose run --rm --service-ports k6-dashboard",
        "test:load:booking": "docker compose run --rm k6-booking",
        "test:load:booking:dashboard": "docker compose run --rm --service-ports k6-booking-dashboard",
        "test:load:email": "docker compose run --rm k6-email",
        "test:load:email:dashboard": "docker compose run --rm --service-ports k6-email-dashboard",
        "test:load:watch-party": "docker compose run --rm k6-watch-party",
        "test:load:watch-party:dashboard": "docker compose run --rm --service-ports k6-watch-party-dashboard",
        "test:frontend": "vitest --project frontend",
        "test:backend": "vitest --project backend",
        "test:mutation": "stryker run",
        "test:integration": "vitest --project integration",
        "typecheck": "tsc --noEmit",
        "sync:movies": "pnpm tsx scripts/syncMovies.ts"
    },
    "dependencies": {
        "@prisma/client": "^6.6.0",
        "@radix-ui/react-icons": "^1.3.2",
        "@radix-ui/react-slot": "^1.2.3",
        "@react-email/components": "1.0.7",
        "@react-email/render": "^2.0.4",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.95.3",
        "@t3-oss/env-nextjs": "^0.12.0",
        "@tanstack/react-query": "^5.69.0",
        "@trpc/client": "^11.0.0",
        "@trpc/react-query": "^11.0.0",
        "@trpc/server": "^11.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns-tz": "^3.2.0",
        "lucide-react": "^0.563.0",
        "motion": "^12.32.0",
        "nanoid": "^5.1.7",
        "next": "^15.2.3",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-konva": "^19.2.2",
        "resend": "^6.9.2",
        "server-only": "^0.0.1",
        "sonner": "^2.0.7",
        "superjson": "^2.2.1",
        "tailwind-merge": "^3.4.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@stryker-mutator/core": "^9.6.0",
        "@stryker-mutator/jest-runner": "^9.6.0",
        "@stryker-mutator/vitest-runner": "^9.6.0",
        "@tailwindcss/postcss": "^4.0.15",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/k6": "^1.7.0",
        "@types/node": "^20.14.10",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^5.1.3",
        "dotenv": "^17.2.4",
        "dotenv-cli": "^11.0.0",
        "eslint": "8.57.1",
        "eslint-config-next": "^16.1.6",
        "happy-dom": "^20.5.1",
        "jest": "^30.3.0",
        "postcss": "^8.5.3",
        "prettier": "^3.5.3",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "prisma": "^6.6.0",
        "shadcn": "^3.8.5",
        "tailwindcss": "^4.0.15",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.27.0",
        "vite-tsconfig-paths": "^6.1.0",
        "vitest": "^4.0.18"
    },
    "ct3aMetadata": {
        "initVersion": "7.40.0"
    },
    "packageManager": "pnpm@10.15.0"
}
