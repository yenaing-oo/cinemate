// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model User {
    id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    supabaseId       String? @unique
    name             String?
    email            String  @unique
    imageURL         String?
    hasPaymentMethod Boolean @default(false)

    // Cinemate relations
    bookings       Booking[]
    heldSeats      ShowtimeSeat[]
    bookingSession BookingSession?
}

// ==================== MOVIES ====================

model Movie {
    id          String   @id @default(cuid())
    tmdbId      Int      @unique //TMDB ID
    title       String
    description String?  @db.Text
    runtime     Int // Duration in minutes
    rating      Float? // Average rating (e.g., 8.5)
    releaseDate DateTime
    posterUrl   String?
    backdropUrl String?
    trailerUrl  String?
    genres      String? // Comma-separated: "Action, Sci-Fi, Thriller"
    languages   String? // Comma-separated: "English, Spanish"
    cast        String?  @db.Text // Comma-separated: "Tom Hanks, Meg Ryan"
    directors   String? // Comma-separated: "Christopher Nolan"
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    showtimes Showtime[]

    @@index([title])
    @@index([releaseDate])
}

// ==================== SEATS ====================

model Seat {
    id     String @id @default(cuid())
    row    Int // Row number (1=A, 2=B, etc.)
    number Int // Seat number within row

    showtimeSeats ShowtimeSeat[]

    @@unique([row, number])
}

// ==================== SHOWTIMES ====================

model Showtime {
    id        String   @id @default(cuid())
    movieId   String
    movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
    startTime DateTime
    endTime   DateTime
    price     Decimal  @db.Decimal(10, 2)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    showtimeSeats   ShowtimeSeat[]
    bookings        Booking[]
    bookingSessions BookingSession[]
    @@unique([movieId, startTime])
    @@index([movieId])
    @@index([startTime])
    @@index([movieId, startTime])
}

// ==================== BOOKINGS & TICKETS ====================

model Booking {
    id            String        @id @default(cuid())
    bookingNumber Int           @unique @default(autoincrement())
    userId        String        @db.Uuid
    user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    showtimeId    String
    showtime      Showtime      @relation(fields: [showtimeId], references: [id])
    totalAmount   Decimal       @db.Decimal(10, 2)
    status        BookingStatus @default(CONFIRMED)
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt

    tickets Ticket[]

    @@index([userId])
    @@index([showtimeId])
    @@index([status])
}

enum BookingStatus {
    CONFIRMED
    CANCELLED
}

model Ticket {
    id             String       @id @default(cuid())
    bookingId      String
    booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
    showtimeSeatId String
    showtimeSeat   ShowtimeSeat @relation(fields: [showtimeSeatId], references: [id], onDelete: Cascade)
    price          Decimal      @db.Decimal(10, 2)
    status         TicketStatus @default(VALID)
    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt

    @@index([bookingId])
    @@index([showtimeSeatId])
}

enum TicketStatus {
    VALID
    CANCELLED
}

// ==================== SEAT AVAILABILITY ====================

// Denormalized table for efficient seat availability queries
// One row entry per seat per showtime - created when showtime is created
model ShowtimeSeat {
    id               String          @id @default(cuid())
    showtimeId       String
    showtime         Showtime        @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
    seatId           String
    seat             Seat            @relation(fields: [seatId], references: [id], onDelete: Cascade)
    isBooked         Boolean         @default(false)
    // Temporary hold fields for seat selection process
    heldByUserId     String?         @db.Uuid
    heldBy           User?           @relation(fields: [heldByUserId], references: [id], onDelete: SetNull)
    heldTill         DateTime?
    updatedAt        DateTime        @updatedAt
    bookingSession   BookingSession? @relation(fields: [bookingSessionId], references: [id])
    bookingSessionId String?

    tickets Ticket[]

    @@unique([showtimeId, seatId])
    @@index([heldByUserId, heldTill])
    @@index([heldTill])
}

// ==================== BOOKING SESSION ====================

model BookingSession {
    id            String         @id @default(cuid())
    userId        String?        @unique @db.Uuid
    user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
    showtimeId    String
    showtime      Showtime       @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
    step          BookingStep
    ticketCount   Int?
    selectedSeats ShowtimeSeat[]
    startedAt     DateTime       @default(now())
    expiresAt     DateTime
    lastUpdatedAt DateTime       @updatedAt

    @@index([userId])
    @@index([showtimeId])
    @@index([expiresAt])
}

enum BookingStep {
    TICKET_QUANTITY
    SEAT_SELECTION
    CHECKOUT
    COMPLETED
}
