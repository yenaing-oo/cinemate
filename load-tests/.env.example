# Base URL determines whether target is local or live.
# docker-compose maps host.docker.internal for local runs on macOS, Windows, and Linux.
BASE_URL=http://host.docker.internal:3000
# BASE_URL=https://cinemate-latest-preview-latest.onrender.com/

# Shared movie/showtime inputs
NOW_PLAYING_LIMIT=20

# Shared load profile defaults
LOAD_VUS=20
LOAD_DURATION=5m
# Optional
# LOAD_GRACEFUL_STOP=30s

# Optional per-suite overrides
# MOVIE_SHOWTIME_LOAD_DURATION=5m
BOOKING_LOAD_VUS=20
BOOKING_LOAD_DURATION=5m
WATCH_PARTY_LOAD_VUS=10
WATCH_PARTY_LOAD_DURATION=5m
# Required in both the app env and this file for booking load testing
LOAD_TEST_MODE=true

# Shared pacing
SLEEP_SECONDS=1
# ITERATION_SECONDS=12

# Booking suite inputs
BOOKING_TICKET_COUNT=1
# Default seed + k6 email pattern. The booking seed script will create one user per VU.
BOOKING_USER_EMAIL_PREFIX=booking-loadtest
BOOKING_USER_EMAIL_DOMAIN=example.com
# Optional explicit override if you do not want the generated email pattern.
# TEST_USER_EMAILS=booking-loadtest-01@example.com,booking-loadtest-02@example.com

# Watch party suite inputs
# Default seed + k6 email patterns. The watch party seed script creates one host
# and one participant user per VU.
WATCH_PARTY_HOST_EMAIL_PREFIX=watch-party-host-loadtest
WATCH_PARTY_PARTICIPANT_EMAIL_PREFIX=watch-party-participant-loadtest
WATCH_PARTY_USER_EMAIL_DOMAIN=example.com
# Optional explicit overrides if you do not want the generated email pattern.
# WATCH_PARTY_HOST_EMAILS=watch-party-host-loadtest-01@example.com,watch-party-host-loadtest-02@example.com
# WATCH_PARTY_PARTICIPANT_EMAILS=watch-party-participant-loadtest-01@example.com,watch-party-participant-loadtest-02@example.com
